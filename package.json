{
  "name": "@mag-cie/mcp-microsoft-todo",
  "version": "1.0.0",
  "description": "MCP server for Microsoft To Do via the Microsoft Graph API. Stdio transport, MSAL device code auth, local install. Compatible with Claude Code, Claude Desktop, Cursor, and any stdio MCP client.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-microsoft-todo": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "auth": "tsx src/auth.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "microsoft-todo",
    "microsoft-graph",
    "todo",
    "tasks"
  ],
  "author": "MAG&Cie <antoine.guittet@mag-cie.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mag-cie/mcp-microsoft-todo.git"
  },
  "bugs": {
    "url": "https://github.com/mag-cie/mcp-microsoft-todo/issues"
  },
  "homepage": "https://github.com/mag-cie/mcp-microsoft-todo#readme",
  "publishConfig": {
    "access": "public"
  }
}
